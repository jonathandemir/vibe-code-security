# Vouch API – Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase Pooler URI (IPv4 compatible).
# Get it from: Supabase Dashboard → Settings → Database → Connection string → Pooler
DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ── AI Engine ─────────────────────────────────────────────────────────────────
# Get it from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
# A random secret for the master API key (for admin/CLI use)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
VOUCH_API_KEY=

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Your production frontend URL. Used for CORS and GitHub App redirects.
# Example: https://vouch-secure.com or https://vouch-dashboard.vercel.app
FRONTEND_URL=http://localhost:5173

# ── GitHub App ────────────────────────────────────────────────────────────────
# Get from: GitHub → Settings → Developer Settings → GitHub Apps → Your App
GITHUB_APP_ID=
# The full content of the .pem private key file (replace newlines with \n)
GITHUB_PRIVATE_KEY=
# A random secret you set when creating the GitHub App Webhook
GITHUB_WEBHOOK_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_live_...
# Get from: https://dashboard.stripe.com/webhooks (after creating the endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
