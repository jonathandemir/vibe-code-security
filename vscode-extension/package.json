{
    "name": "vibeguard",
    "displayName": "VibeGuard Security Scanner",
    "description": "The Stripe of App-Security: AI-powered automated vulnerability fixes for Vibe-Coders.",
    "version": "0.1.0",
    "publisher": "vibeguard-hq",
    "repository": {
        "type": "git",
        "url": "https://github.com/vibeguard-hq/vibe-code-security.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/main.js",
    "contributes": {
        "commands": [
            {
                "command": "vibeguard.scanFile",
                "title": "VibeGuard: Scan Current File"
            }
        ],
        "configuration": {
            "title": "VibeGuard API Configuration",
            "properties": {
                "vibeguard.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Your VibeGuard API Key (found in Dashboard)"
                },
                "vibeguard.apiUrl": {
                    "type": "string",
                    "default": "https://vibe-code-security-api.onrender.com",
                    "description": "VibeGuard Base API URL"
                }
            }
        },
        "menus": {
            "editor/context": [
                {
                    "command": "vibeguard.scanFile",
                    "group": "security@1"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run esbuild",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/main.js --external:vscode --format=cjs --platform=node",
        "esbuild": "npm run esbuild-base -- --sourcemap",
        "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch"
    },
    "devDependencies": {
        "@types/node": "^18.x",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.1.3",
        "esbuild": "^0.18.11"
    },
    "dependencies": {
        "axios": "^1.4.0"
    }
}